# ============================================================
# RumbleX Indexer API — Environment Template
# Copy to .env and fill in real values.
# This file is loaded by dotenv.config() when the service starts.
# Never commit .env — it is listed in .gitignore.
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Monad testnet RPC endpoint (public or private Alchemy/Infura).
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Chain ID for Monad testnet.  The indexer verifies this against the manifest.
MONAD_CHAIN_ID=10143

# ── Optional overrides ────────────────────────────────────────
# Absolute or relative path to the deployment manifest JSON.
# Defaults to <repo-root>/onchain/deployments/monad-testnet.json.
# DEPLOYMENT_MANIFEST_PATH=

# Path for the indexer's local JSON database.
# Defaults to <repo-root>/services/indexer-api/data/indexer-db.json.
# INDEXER_DB_PATH=

# Override the first block the indexer polls from.
# Leave blank to use startBlock values from the manifest.
# INDEXER_START_BLOCK=

INDEXER_POLL_INTERVAL_MS=12000
INDEXER_CONFIRMATION_BLOCKS=3
INDEXER_STALE_AFTER_MS=120000
INDEXER_API_PORT=8787

# ── Smoke test ────────────────────────────────────────────────
# Used only by scripts/smoke.ts, not by the API itself.
# INDEXER_API_BASE_URL=http://localhost:8787
# SMOKE_ADDRESS=0xYourWalletAddress
