# ============================================================
# RumbleX — Environment Template
# Copy to .env.local and fill in real values.
# Never commit .env.local or any file containing secrets.
# ============================================================

# ── Onchain / RPC ───────────────────────────────────────────
# Public or private Monad testnet RPC endpoint.
MONAD_RPC_URL="https://testnet-rpc.monad.xyz"

# Chain ID for Monad testnet (10143).  The indexer verifies this at startup.
MONAD_CHAIN_ID="10143"

# ── Indexer API ─────────────────────────────────────────────
# Path to the deployment manifest JSON.
# Defaults to <repo-root>/onchain/deployments/monad-testnet.json — leave
# blank unless you need to override (e.g. in Docker or CI).
# DEPLOYMENT_MANIFEST_PATH=

# Path for the indexer's local JSON database.
# Defaults to <repo-root>/services/indexer-api/data/indexer-db.json.
# INDEXER_DB_PATH=

# Override the first block the indexer polls from (optional).
# Leave blank to use the startBlock values from the deployment manifest.
# INDEXER_START_BLOCK=

INDEXER_POLL_INTERVAL_MS="12000"
INDEXER_CONFIRMATION_BLOCKS="3"
INDEXER_STALE_AFTER_MS="120000"
INDEXER_API_PORT="8787"

# ── Frontend ─────────────────────────────────────────────────
# Data source mode for the Vite frontend.
#   mock   — all data from local fixtures, no RPC or API required
#   hybrid — wallet summary / pass / claim use the indexer API
#   live   — same as hybrid for the current MVP
VITE_DATA_MODE="mock"

# Base URL of the running indexer-api (used in hybrid/live modes).
VITE_API_BASE_URL="http://localhost:8787"
