# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Indexer/API service (Monad testnet)
MONAD_RPC_URL="https://your-monad-rpc"
MONAD_CHAIN_ID="10143"
DEPLOYMENT_MANIFEST_PATH="/Users/ricky/AICode/RumbleX/onchain/deployments/monad-testnet.json"
INDEXER_DB_PATH="/Users/ricky/AICode/RumbleX/services/indexer-api/data/indexer-db.json"
INDEXER_START_BLOCK="0"
INDEXER_POLL_INTERVAL_MS="12000"
INDEXER_CONFIRMATION_BLOCKS="3"
INDEXER_STALE_AFTER_MS="120000"
INDEXER_API_PORT="8787"

# Frontend data source mode:
# - mock: use all mock data/transactions
# - hybrid: wallet summary/pass/claim use API, other views can stay mock
# - live: wallet summary/pass/claim use API (same as hybrid for current MVP)
VITE_DATA_MODE="hybrid"
VITE_API_BASE_URL="http://localhost:8787"
