# ============================================================
# RumbleX — Root Environment Template
#
# This file is the template for <repo-root>/.env.local.
# Usage:
#   cp .env.example .env.local
#
# Which layer reads which file:
#   Frontend (Vite)           → <repo-root>/.env.local   ← this file
#   validate-manifest.ts      → <repo-root>/.env.local   ← this file
#   Indexer API (dotenv.config()) → services/indexer-api/.env
#                                   (see services/indexer-api/.env.example)
#
# INDEXER_* vars in this file are NOT read by the indexer when it runs
# via `npm run indexer:api` from the repo root.  Set them in
# services/indexer-api/.env instead.
# ============================================================

# ── Onchain / RPC (used by validate-manifest.ts) ────────────
# Public or private Monad testnet RPC endpoint.
MONAD_RPC_URL="https://testnet-rpc.monad.xyz"

# Chain ID for Monad testnet (10143).
MONAD_CHAIN_ID="10143"

# ── Frontend (Vite only) ─────────────────────────────────────
# Data source mode for the Vite frontend.
#   mock   — all data from local fixtures, no RPC or API required
#   hybrid — wallet summary / pass / claim use the indexer API
#   live   — same as hybrid for the current MVP
VITE_DATA_MODE="mock"

# Base URL of the running indexer-api (used in hybrid/live modes).
VITE_API_BASE_URL="http://localhost:8787"

# ── Indexer reference (NOT read from this file by the indexer) ─
# These variables must be set in services/indexer-api/.env.
# They are listed here for documentation purposes only.
#
# MONAD_RPC_URL         → already set above (validate-manifest shares it)
# MONAD_CHAIN_ID        → already set above
# DEPLOYMENT_MANIFEST_PATH  default: <repo-root>/onchain/deployments/monad-testnet.json
# INDEXER_DB_PATH           default: <repo-root>/services/indexer-api/data/indexer-db.json
# INDEXER_START_BLOCK       optional: overrides manifest startBlock
# INDEXER_POLL_INTERVAL_MS  default: 12000
# INDEXER_CONFIRMATION_BLOCKS default: 3
# INDEXER_STALE_AFTER_MS    default: 120000
# INDEXER_API_PORT          default: 8787
#
# Copy services/indexer-api/.env.example to services/indexer-api/.env
# and set MONAD_RPC_URL + MONAD_CHAIN_ID there.
